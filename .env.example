GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

WHATSAPP_API_KEY=
WHATSAPP_FROM=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_SESSION_MESSAGE_URL=

DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DB_SCHEMA=chatbot

VALKEY_URL=valkey://:password@host:6379/0
VALKEY_PREFIX=chatbot:

JPUS_API_BASE=http://127.0.0.1:8000

# --- SMTP (email notifications). Empty SMTP_HOST disables email entirely. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# OpenAPI docs (/docs, /redoc, /openapi.json). Off by default — these
# enumerate every admin route and schema. Set to true in dev/staging only.
DOCS_ENABLED=false

# Used in deeplinks inside emails (and as the OAuth redirect base)
PUBLIC_BASE_URL=https://chatbot.janapriyahomes.com

# --- Microsoft 365 / Entra ID OAuth (strict allowlist).
# Empty values disable the "Sign in with Microsoft" button. ---
O365_TENANT_ID=
O365_CLIENT_ID=
O365_CLIENT_SECRET=
O365_REDIRECT_PATH=/auth/o365/callback
